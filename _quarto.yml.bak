project:
  type: book

book:
  title: "ラグランジェ・ファイナンス"
  subtitle: "金融工学システム構築入門"
  author: "Eiichi Horigome"

  chapters:
    - index.qmd

    - part: "第I部 実証会計・ファイナンス"
      chapters:
        - part1_empirical/ch01_r_basics_tidyverse.qmd
        - part1_empirical/ch02_financial_data.qmd
        - part1_empirical/ch03_stock_data_time_series.qmd
        - part1_empirical/ch04_factor_models.qmd
        - part1_empirical/ch05_asset_pricing.qmd
        - part1_empirical/ch06_event_study.qmd

    - part: "第II部 金融工学と金融数学"
      chapters:
        - part2_quantive_riemann/ch07_bonds.qmd
        - part2_quantive_riemann/ch08_treasury_futures_ctd.qmd
        - part2_quantive_riemann/ch09_ois_swaps_multicurve.qmd
        - part2_quantive_riemann/ch10_black_model.qmd
        - part2_quantive_riemann/ch11_normal_model.qmd
        - part2_quantive_riemann/ch12_sabr_model.qmd
        - part2_quantive_riemann/ch13_callable_hull_white.qmd
        - part2_quantive_riemann/ch14_credit_risk_cds.qmd
        - part2_quantive_riemann/ch15_exotic_derivatives_prdc.qmd

format:
  html:
    theme: cosmo
    toc: true
    code-fold: false
    number-sections: false

execute:
  eval: true
  echo: true
  warning: false
  message: false
  error: true
